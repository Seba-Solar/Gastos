<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categoria Actualizar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
    <%- include('../views/partials/navbar') %>
<div class="container mb-4">
    <h2>Actualizar Categoria</h2>
    <form action="/categorias/editar/categoria/<%= categorias.idCategoria_Gasto %>" method="POST" >
        <input class="form-control mb-2" name="nombreCategoria" value="<%= categorias.nombreCategoria %>" required>
    
        <button class="btn btn-success btn-sm">Actualizar</button>
        <a href="/categorias" class="btn btn-secondary">Volver</a>
    </form>
</div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>