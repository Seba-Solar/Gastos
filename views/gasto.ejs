<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Gastos demo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  </head>
<body>


<%- include('../views/partials/navbar') %>

<div class="container mt-4">

  <h1 class="mb-4">Lista de Gastos</h1>

  <a href="/gastos/crear_gasto" class="btn btn-primary mb-3">Nuevo Gasto</a>

  <table class="table table-bordered table-hover">
    <thead class="table-dark">
      <tr>
        <th>Nombre</th>
        <th>Descripción</th>
        <th>Monto</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% objetoGastos.forEach(g => { %>
        <tr>
          <td><%= g.nombreGasto %></td>
          <td><%= g.descripcionGasto %></td>
          <td>$<%= g.montoGasto %></td>
          <td>
            <form action="/gastos/actualizar_gasto/<%= g.idGasto %>" method="POST">
              <button class="btn btn-warning btn-sm">Editar</button>
            </form>
            <form action="/gastos/eliminar/<%= g.idGasto %>" method="POST" style="display:inline;">
              <button class="btn btn-danger btn-sm">Eliminar</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>