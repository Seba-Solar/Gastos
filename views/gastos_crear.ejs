<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gasto Crear</title>
     <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
    
<div class="container mt-4">
  <h2>Nuevo Gasto</h2>

  <form action="/gastos/crear" method="POST">
    <input class="form-control mb-2" name="nombreGasto" placeholder="Nombre" required>
    
    <input class="form-control mb-2" name="descripcionGasto" placeholder="Descripción">
    <input class="form-control mb-2" name="montoGasto" type="number" placeholder="Monto" required>
    
    <select class="form-select mb-2" name="idCategoriaGasto" required>
      <option value="">Selecciona categoría</option>
      <% categoria.forEach(c => { %>
        <option value="<%= c.idCategoria_Gasto %>">
          <%= c.nombreCategoria %>
        </option>
      <% }) %>
    </select>

    <select class="form-select mb-2" name="idMetodoPago" required>
      <option value="">Selecciona método</option>
      <% metodo.forEach(m => { %>
        <option value="<%= m.idmetodo_pago %>">
          <%= m.tipoPago %>
        </option>
      <% }) %>
    </select>

    <button class="btn btn-success">Guardar</button>
    <a href="/gastos" class="btn btn-secondary">Volver</a>
  </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>